CONFIG_FILE = os.path.expanduser('~/.pys3')

def format_speed(bytes_count, seconds):
    """Helper to calculate and format bandwidth speeds."""
    if seconds <= 0:
        return "∞ B/s"
    bps = bytes_count / seconds
    for unit in ['B/s', 'KB/s', 'MB/s', 'GB/s']:
        if bps < 1024.0:
            return f"{bps:.2f} {unit}"
        bps /= 1024.0
    return f"{bps:.2f} TB/s"

def format_size(bytes_count):
    """Helper to format file sizes for ls -lh."""
    if bytes_count < 1024:
        return f"{bytes_count} B"
    for unit in ['KB', 'MB', 'GB', 'TB']:
        bytes_count /= 1024.0
        if bytes_count < 1024.0:
            return f"{bytes_count:.1f} {unit}"
    return f"{bytes_count:.1f} PB"


class S3SigV4Client:
    """A lightweight S3 client using standard libraries and AWS Signature V4."""
    def __init__(self, endpoint, region, access_key, secret_key, bucket):
        self.endpoint = endpoint.rstrip('/')
        
        # Auto-correct missing HTTP/HTTPS scheme
        if not self.endpoint.startswith(('http://', 'https://')):
            print(f"[WARNING] Endpoint '{self.endpoint}' is missing a scheme. Assuming 'https://'...")
            self.endpoint = 'https://' + self.endpoint
            
        self.region = region if region else 'us-east-1' # Default region if empty in config
        self.access_key = access_key
        self.secret_key = secret_key
        self.bucket = bucket
        self.host = urllib.parse.urlparse(self.endpoint).netloc

    def sign_request(self, method, path, query_params=None, payload=b''):
        t = datetime.datetime.utcnow()
        amz_date = t.strftime('%Y%m%dT%H%M%SZ')
        datestamp = t.strftime('%Y%m%d')

        canonical_uri = urllib.parse.quote(path, safe='/~')
        
        if query_params:
            canonical_querystring = urllib.parse.urlencode(sorted(query_params.items()))
        else:
            canonical_querystring = ''

        payload_hash = hashlib.sha256(payload).hexdigest()
        canonical_headers = f'host:{self.host}\nx-amz-content-sha256:{payload_hash}\nx-amz-date:{amz_date}\n'
        signed_headers = 'host;x-amz-content-sha256;x-amz-date'

        canonical_request = f"{method}\n{canonical_uri}\n{canonical_querystring}\n{canonical_headers}\n{signed_headers}\n{payload_hash}"
        
        algorithm = 'AWS4-HMAC-SHA256'
        credential_scope = f"{datestamp}/{self.region}/s3/aws4_request"
        string_to_sign = f"{algorithm}\n{amz_date}\n{credential_scope}\n{hashlib.sha256(canonical_request.encode('utf-8')).hexdigest()}"

        k_date = hmac.new(f'AWS4{self.secret_key}'.encode('utf-8'), datestamp.encode('utf-8'), hashlib.sha256).digest()
        k_region = hmac.new(k_date, self.region.encode('utf-8'), hashlib.sha256).digest()
        k_service = hmac.new(k_region, b's3', hashlib.sha256).digest()
        k_signing = hmac.new(k_service, b'aws4_request', hashlib.sha256).digest()

        signature = hmac.new(k_signing, string_to_sign.encode('utf-8'), hashlib.sha256).hexdigest()
        authorization_header = f"{algorithm} Credential={self.access_key}/{credential_scope}, SignedHeaders={signed_headers}, Signature={signature}"

        headers = {
            'x-amz-date': amz_date,
            'x-amz-content-sha256': payload_hash,
            'Authorization': authorization_header
        }
        return headers, canonical_querystring

    def make_request(self, method, key, query_params=None, payload=b''):
        path = f"/{self.bucket}/{key}" if key else f"/{self.bucket}"
        headers, qs = self.sign_request(method, path, query_params, payload)
        url = f"{self.endpoint}{path}"
        if qs:
            url += f"?{qs}"

        try:
            req = urllib.request.Request(url, data=payload if payload else None, headers=headers, method=method)
            with urllib.request.urlopen(req, timeout=10) as response:
                return response.read(), response.status
        except urllib.error.HTTPError as e:
            return e.read(), e.code
        except urllib.error.URLError as e:
            print(f"\n[ERROR] Network issue connecting to {self.endpoint}")
            print(f"Reason: {e.reason}")
            print("Please check your DNS resolution and ensure the endpoint is reachable.")
            return b'', None
        except ValueError as e:
            print(f"\n[ERROR] Invalid URL formatting: {e}")
            return b'', None
        except Exception as e:
            print(f"\n[ERROR] An unexpected error occurred: {e}")
            return b'', None

    def list_objects(self, prefix="", delimiter="", silent=False):
        query = {'list-type': '2'}
        if prefix: query['prefix'] = prefix
        if delimiter: query['delimiter'] = delimiter
        
        data, status = self.make_request('GET', '', query)
        if status is None:
            return [] 
            
        if status == 200:
            root = ET.fromstring(data)
            ns = {'s3': root.tag.split('}')[0].strip('{')} if '}' in root.tag else {}
            
            results = []
            
            # Simulated directories (from delimiter)
            for cp in root.findall('.//s3:CommonPrefixes' if ns else './/CommonPrefixes', ns):
                p = cp.find('s3:Prefix' if ns else 'Prefix', ns).text
                results.append({'key': p, 'size': 0, 'is_dir': True})
            
            # Actual objects
            for c in root.findall('.//s3:Contents' if ns else './/Contents', ns):
                key = c.find('s3:Key' if ns else 'Key', ns).text
                size = int(c.find('s3:Size' if ns else 'Size', ns).text)
                results.append({'key': key, 'size': size, 'is_dir': False})
                
            return results
            
        elif not silent:
            if status == 403:
                print("Error 403: Access Denied. Your credentials might be wrong or you lack permissions for this bucket.")
            else:
                print(f"Error listing objects: HTTP {status} - {data.decode('utf-8', errors='ignore')}")
        return []

    def download_file(self, key, local_path):
        start_time = time.time()
        data, status = self.make_request('GET', key)
        if status is None:
            return
            
        duration = time.time() - start_time
        
        if status == 200:
            with open(local_path, 'wb') as f:
                f.write(data)
            speed = format_speed(len(data), duration)
            print(f"Downloaded: {key} -> {local_path} ({len(data)} bytes at {speed})")
        elif status == 403:
            print(f"Error 403: Access Denied to '{key}'. Check your credentials.")
        elif status == 404:
            print(f"Error 404: File '{key}' not found.")
        else:
            print(f"Error downloading {key}: HTTP {status}")

    def upload_file(self, local_path, key):
        if not os.path.isfile(local_path):
            print(f"File not found: {local_path}")
            return
        with open(local_path, 'rb') as f:
            payload = f.read()
            
        start_time = time.time()
        data, status = self.make_request('PUT', key, payload=payload)
        if status is None:
            return
            
        duration = time.time() - start_time
        
        if status == 200:
            speed = format_speed(len(payload), duration)
            print(f"Uploaded: {local_path} -> {key} ({len(payload)} bytes at {speed})")
        elif status == 403:
            print(f"Error 403: Access Denied. You do not have permission to write to '{key}'.")
        else:
            print(f"Error uploading {local_path}: HTTP {status}\n{data.decode('utf-8', errors='ignore')}")


class PyS3Shell(cmd.Cmd):
    """Interactive ncftp-like shell for S3."""
    intro = 'Welcome to pys3 interactive shell. Type help or ? to list commands.\n'

    def __init__(self, client):
        super().__init__()
        self.client = client
        self.prefix = ""
        self.update_prompt()
        
        # Configure readline to NOT split words on slashes (/) for path completion
        try:
            import readline
            readline.set_completer_delims(' \t\n;')
        except ImportError:
            pass # Windows or system without readline

    def update_prompt(self):
        display_prefix = f"/{self.prefix}" if self.prefix else "/"
        self.prompt = f"pys3 ({self.client.bucket}{display_prefix})> "

    # --- COMPLETION HELPERS ---
    def _complete_remote(self, text, line, is_dir_only=False):
        """Helper to fetch S3 completion matches based on user input."""
        if '/' in text:
            dir_part = text[:text.rfind('/')+1]
            file_part = text[text.rfind('/')+1:]
        else:
            dir_part = ""
            file_part = text
            
        search_prefix = self.prefix + dir_part
        
        # Use silent=True so background tab-completion doesn't print S3 errors to screen
        objects = self.client.list_objects(prefix=search_prefix, delimiter='/', silent=True)
            
        completions = []
        for obj in objects:
            key = obj['key']
            if key == search_prefix:
                continue
                
            rel_name = key[len(search_prefix):]
            if rel_name.startswith(file_part):
                if is_dir_only and not obj['is_dir']:
                    continue
                completions.append(dir_part + rel_name)
                
        return completions

    def _complete_local(self, text, line):
        """Helper to fetch local filesystem completion matches."""
        path = text + '*'
        matches = glob.glob(path)
        completions = []
        for m in matches:
            if os.path.isdir(m):
                completions.append(m + '/')
            else:
                completions.append(m)
        return completions

    # --- TAB COMPLETION HOOKS ---
    def complete_cd(self, text, line, begidx, endidx):
        return self._complete_remote(text, line, is_dir_only=True)

    def complete_ls(self, text, line, begidx, endidx):
        if text.startswith('-'): return []
        return self._complete_remote(text, line)
        
    def complete_find(self, text, line, begidx, endidx):
        return self._complete_remote(text, line)
        
    def complete_mkdir(self, text, line, begidx, endidx):
        return self._complete_remote(text, line, is_dir_only=True)
        
    def complete_cat(self, text, line, begidx, endidx):
        return self._complete_remote(text, line)

    def complete_get(self, text, line, begidx, endidx):
        args = line.split()
        if len(args) == 2 and line.endswith(' '): # Typing the 2nd arg (local file)
            return self._complete_local(text, line)
        elif len(args) > 2: # Already typed 2nd arg
            return self._complete_local(text, line)
        else: # Completing 1st arg (remote file)
            return self._complete_remote(text, line)

    def complete_put(self, text, line, begidx, endidx):
        args = line.split()
        if len(args) == 2 and line.endswith(' '): # Typing 2nd arg (remote location)
            return self._complete_remote(text, line)
        elif len(args) > 2: # Already typed 2nd arg
            return self._complete_remote(text, line)
        else: # Completing 1st arg (local file)
            return self._complete_local(text, line)

    # --- COMMANDS ---
    def do_find(self, arg):
        """Recursively list all objects under the current prefix (like old ls)."""
        search_prefix = self.prefix + arg if arg else self.prefix
        objects = self.client.list_objects(prefix=search_prefix) # No delimiter = recursive
        for obj in objects:
            key = obj['key']
            display_name = key[len(self.prefix):] if key.startswith(self.prefix) else key
            print(display_name)

    def do_ls(self, arg):
        """List contents of the current directory. Options: -l, -h, -lh"""
        show_long = '-l' in arg
        show_human = '-h' in arg or '-lh' in arg or '-hl' in arg
        if '-lh' in arg or '-hl' in arg:
            show_long = True
            
        clean_arg = arg.replace('-lh', '').replace('-hl', '').replace('-l', '').replace('-h', '').strip()
        
        search_prefix = self.prefix + clean_arg if clean_arg else self.prefix
        if search_prefix and not search_prefix.endswith('/') and clean_arg:
            search_prefix += '/'

        objects = self.client.list_objects(prefix=search_prefix, delimiter='/')
        
        for obj in objects:
            key = obj['key']
            if key == search_prefix:
                continue
                
            display_name = key[len(search_prefix):] if key.startswith(search_prefix) else key
            
            if show_long:
                if obj['is_dir']:
                    print(f"{'DIR':>10}  {display_name}")
                else:
                    size_str = format_size(obj['size']) if show_human else str(obj['size'])
                    print(f"{size_str:>10}  {display_name}")
            else:
                print(display_name)

    def do_cd(self, arg):
        """Change directory (prefix). Use 'cd /' to go to root."""
        if not arg or arg == '/':
            self.prefix = ""
        elif arg == '..':
            parts = [p for p in self.prefix.split('/') if p]
            self.prefix = '/'.join(parts[:-1]) + '/' if len(parts) > 1 else ""
        else:
            new_prefix = self.prefix + arg
            if not new_prefix.endswith('/'):
                new_prefix += '/'
            self.prefix = new_prefix
        self.update_prompt()

    def do_mkdir(self, arg):
        """Create a directory (S3 prefix): mkdir <dirname>"""
        if not arg:
            print("Usage: mkdir <dirname>")
            return
        dirname = arg.strip()
        if not dirname.endswith('/'):
            dirname += '/'
        remote_key = self.prefix + dirname
        
        data, status = self.client.make_request('PUT', remote_key, payload=b'')
        if status is None:
            return
            
        if status == 200:
            print(f"Created directory: {remote_key}")
        elif status == 403:
            print(f"Error 403: Access Denied to create '{remote_key}'.")
        else:
            print(f"Error creating directory {remote_key}: HTTP {status}")

    def do_get(self, arg):
        """Download an object: get <remote_key> [local_path]"""
        args = arg.split()
        if not args:
            print("Usage: get <remote_key> [local_path]")
            return
        remote_key = self.prefix + args[0]
        local_path = args[1] if len(args) > 1 else os.path.basename(args[0])
        self.client.download_file(remote_key, local_path)

    def do_put(self, arg):
        """Upload a local file: put <local_path> [remote_key]"""
        args = arg.split()
        if not args:
            print("Usage: put <local_path> [remote_key]")
            return
        local_path = args[0]
        remote_key = self.prefix + (args[1] if len(args) > 1 else os.path.basename(local_path))
        self.client.upload_file(local_path, remote_key)
        
    def do_cat(self, arg):
        """Print the contents of a remote file to the terminal: cat <remote_key>"""
        if not arg:
            print("Usage: cat <remote_key>")
            return
        remote_key = self.prefix + arg.strip()
        data, status = self.client.make_request('GET', remote_key)
        if status is None:
            return
            
        if status == 200:
            try:
                print(data.decode('utf-8'))
            except UnicodeDecodeError:
                print(f"Error: '{remote_key}' appears to be binary and cannot be printed.")
        elif status == 403:
            print(f"Error 403: Access Denied to '{remote_key}'.")
        elif status == 404:
            print(f"Error 404: File '{remote_key}' not found.")
        else:
            print(f"Error reading {remote_key}: HTTP {status}")

    def do_exit(self, arg):
        """Exit the shell."""
        print("Goodbye!")
        return True
    
    def do_EOF(self, arg):
        print()
        return True


def show_default_config():
    print(f"""
# Save this template to {CONFIG_FILE}
[default]
endpoint = https://s3.amazonaws.com
region = us-east-1
access_key = YOUR_ACCESS_KEY
secret_key = YOUR_SECRET_KEY
bucket = your-bucket-name

[radosgw]
endpoint = http://127.0.0.1:8080
region = default
access_key = YOUR_ACCESS_KEY
secret_key = YOUR_SECRET_KEY
bucket = your-bucket-name
""")

def generate_config_from_obc(obc_name):
    try:
        sec_out = subprocess.check_output(['oc', 'get', 'secret', obc_name, '-o', 'json'], stderr=subprocess.DEVNULL)
        sec_data = json.loads(sec_out).get('data', {})
        access_key = base64.b64decode(sec_data.get('AWS_ACCESS_KEY_ID', b'')).decode()
        secret_key = base64.b64decode(sec_data.get('AWS_SECRET_ACCESS_KEY', b'')).decode()

        cm_out = subprocess.check_output(['oc', 'get', 'cm', obc_name, '-o', 'json'], stderr=subprocess.DEVNULL)
        cm_data = json.loads(cm_out).get('data', {})
        bucket = cm_data.get('BUCKET_NAME', '')
        host = cm_data.get('BUCKET_HOST', '')
        port = cm_data.get('BUCKET_PORT', '443')
        region = cm_data.get('BUCKET_REGION', 'us-east-1')
        
        scheme = 'https' if port == '443' else 'http'
        endpoint = f"{scheme}://{host}:{port}"

        print(f"[{obc_name}]")
        print(f"endpoint = {endpoint}")
        print(f"region = {region}")
        print(f"access_key = {access_key}")
        print(f"secret_key = {secret_key}")
        print(f"bucket = {bucket}")
        print(f"# Append the block above to your {CONFIG_FILE}")
    except subprocess.CalledProcessError:
        print(f"Error: Could not retrieve OpenShift OBC '{obc_name}'. Ensure you are logged in via 'oc login'.")
    except Exception as e:
        print(f"Error processing OBC config: {e}")

def main():
    parser = argparse.ArgumentParser(description="pys3: A standard-library only interactive S3 client.")
    parser.add_argument('--profile', type=str, help="Configuration profile to use from ~/.pys3")
    parser.add_argument('--generate-config', action='store_true', help="Show a default configuration template")
    parser.add_argument('--from-obc', type=str, metavar='OBC_NAME', help="Grab credentials from an OpenShift OBC and output config block")
    parser.add_argument('command', nargs='*', help="Command to execute directly (e.g. ls, get, put, mkdir). If empty, starts shell.")
    
    args = parser.parse_args()

    if args.generate_config:
        show_default_config()
        sys.exit(0)

    if args.from_obc:
        generate_config_from_obc(args.from_obc)
        sys.exit(0)

    if not os.path.exists(CONFIG_FILE):
        print(f"No configuration file found at {CONFIG_FILE}.\n")
        print("To create a default configuration profile, run the following command:")
        print(f"    {sys.argv[0]} --generate-config > {CONFIG_FILE}")
        sys.exit(1)

    config = configparser.ConfigParser()
    config.read(CONFIG_FILE)
    profiles = config.sections()

    if not profiles:
        print(f"The configuration file {CONFIG_FILE} exists but contains no profiles.\n")
        print(f"Run '{sys.argv[0]} --generate-config' to see an example of how to format it.")
        sys.exit(1)

    if not args.profile:
        print("No profile specified. Available profiles in your configuration:")
        for p in profiles:
            print(f"  - {p}")
        print(f"\nPlease select one using: {sys.argv[0]} --profile <profile_name> [command]")
        sys.exit(1)

    if args.profile not in config:
        print(f"Error: Profile '{args.profile}' not found in {CONFIG_FILE}.")
        sys.exit(1)

    c = config[args.profile]
    try:
        client = S3SigV4Client(
            endpoint=c['endpoint'],
            region=c.get('region', ''),
            access_key=c['access_key'],
            secret_key=c['secret_key'],
            bucket=c['bucket']
        )
    except KeyError as e:
        print(f"Missing required configuration key {e} in profile '{args.profile}'")
        sys.exit(1)

    shell = PyS3Shell(client)
    if args.command:
        cmd_line = " ".join(args.command)
        shell.onecmd(cmd_line)
    else:
        shell.cmdloop()

if __name__ == '__main__':
    main()
